{
  "openapi": "3.1.0",
  "info": {
    "title": "site",
    "description": "",
    "version": "0.1.0"
  },
  "paths": {
    "/api/coldstarts": {
      "get": {
        "tags": [
          "coldstarts"
        ],
        "operationId": "getColdstartStats",
        "responses": {
          "200": {
            "description": "Per-app cold/warm aggregates (empty when the store is unconfigured, e.g. local dev)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColdstartStats"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "coldstarts"
        ],
        "operationId": "ingestColdstarts",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ColdstartSample"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Samples stored",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or wrong x-api-key"
          },
          "503": {
            "description": "Metrics store not configured"
          }
        }
      }
    },
    "/api/ping": {
      "get": {
        "tags": [
          "ping"
        ],
        "operationId": "getApiPing",
        "responses": {
          "200": {
            "description": "Pong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "ping"
        ],
        "operationId": "sendPing",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Echoes the posted message",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppStats": {
        "type": "object",
        "description": "Per-app aggregate served by GET.",
        "required": [
          "app",
          "target",
          "samples",
          "cold",
          "warm",
          "prewarmed",
          "errors",
          "burst_requests",
          "burst_colds",
          "edge_regions",
          "function_regions",
          "expected_regions",
          "cdn_hits",
          "cdn_misses"
        ],
        "properties": {
          "app": {
            "type": "string"
          },
          "burst_colds": {
            "type": "integer",
            "format": "int64"
          },
          "burst_requests": {
            "type": "integer",
            "format": "int64",
            "description": "Burst-phase totals (the concurrency probe): how many requests the\napp's instances absorbed, and how many required a fresh instance."
          },
          "cdn_hits": {
            "type": "integer",
            "format": "int64"
          },
          "cdn_misses": {
            "type": "integer",
            "format": "int64"
          },
          "cold": {
            "type": "integer",
            "format": "int64"
          },
          "cold_p50_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "cold_p90_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "cold_p95_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "edge_regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Edge POPs that received the requests in this aggregate window."
          },
          "errors": {
            "type": "integer",
            "format": "int64"
          },
          "expected_regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Region configured as the fair-comparison target in metrics/fleet.json."
          },
          "first_ts": {
            "type": [
              "string",
              "null"
            ]
          },
          "function_regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Function regions parsed from x-vercel-id. Empty means no function hop\nwas reported (normally a CDN response) or legacy telemetry."
          },
          "last_ts": {
            "type": [
              "string",
              "null"
            ]
          },
          "prewarmed": {
            "type": "integer",
            "format": "int64",
            "description": "First-request-on-an-idle-instance: flagged cold by the process, but\nthe instance had been up long before (Vercel pre-provisioning), so no\nboot cost was paid. Counted separately; latency folded into warm."
          },
          "samples": {
            "type": "integer",
            "format": "int64"
          },
          "target": {
            "type": "string",
            "description": "\"page\" | \"api\" | \"\" for pre-burst samples."
          },
          "warm": {
            "type": "integer",
            "format": "int64"
          },
          "warm_p50_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "warm_p90_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "warm_p95_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          }
        }
      },
      "ColdstartSample": {
        "type": "object",
        "description": "One pinger observation. `extra` keeps the schema open for expansion —\nanything the pinger learns to measure lands there without a migration.",
        "required": [
          "ts",
          "app"
        ],
        "properties": {
          "app": {
            "type": "string",
            "description": "Fleet app name (metrics/fleet.json)."
          },
          "boot_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Instance boot id reported by /__nx/health."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Transport error, if any."
          },
          "extra": {
            "description": "Open extension point (JSON object)."
          },
          "ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Full response time in ms."
          },
          "ok": {
            "type": "boolean",
            "description": "True when the request completed with status < 500."
          },
          "phase": {
            "type": [
              "string",
              "null"
            ],
            "description": "\"burst\" (concurrent spike) | \"seq\" (sequential, browser-like)."
          },
          "status": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "HTTP status (0 on transport error)."
          },
          "target": {
            "type": [
              "string",
              "null"
            ],
            "description": "What was hit: \"page\" | \"api\" (older samples: null)."
          },
          "temp": {
            "type": [
              "string",
              "null"
            ],
            "description": "\"cold\" | \"warm\" | \"unknown\"."
          },
          "ts": {
            "type": "string",
            "description": "RFC3339 timestamp of the ping."
          },
          "uptime_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Instance uptime reported by /__nx/health."
          },
          "url": {
            "type": [
              "string",
              "null"
            ],
            "description": "URL that was hit."
          }
        }
      },
      "ColdstartStats": {
        "type": "object",
        "required": [
          "apps",
          "total_samples",
          "telemetry_version"
        ],
        "properties": {
          "apps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppStats"
            }
          },
          "telemetry_version": {
            "type": "integer",
            "format": "int64",
            "description": "Bumped whenever methodology changes invalidate the old population.\nExisting raw rows remain recoverable but are excluded from aggregates."
          },
          "total_samples": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "IngestResponse": {
        "type": "object",
        "required": [
          "inserted"
        ],
        "properties": {
          "inserted": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "PingRequest": {
        "type": "object",
        "description": "Request body for `POST /api/ping`.",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Message to echo back in the response."
          }
        }
      },
      "PingResponse": {
        "type": "object",
        "description": "Response returned by both `GET` and `POST /api/ping`.",
        "required": [
          "message",
          "pong"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Echoed back from the request (or a default for `GET`)."
          },
          "pong": {
            "type": "boolean",
            "description": "Always `true` — proves the handler ran."
          }
        }
      }
    }
  }
}