{
  "openapi": "3.1.0",
  "info": {
    "title": "react-todos",
    "description": "",
    "version": "0.1.0"
  },
  "paths": {
    "/api/todos": {
      "get": {
        "tags": [
          "todos"
        ],
        "operationId": "getTodos",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "`\"open\"` returns only unfinished todos; anything else returns all.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List todos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Todo"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "todos"
        ],
        "operationId": "addTodo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTodoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The created todo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                }
              }
            }
          }
        }
      }
    },
    "/api/todos/{id}": {
      "get": {
        "tags": [
          "todos"
        ],
        "operationId": "getApiTodosById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          },
          {
            "name": "neighbors",
            "in": "query",
            "description": "Include prev/next ids for detail-page navigation.",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The todo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoDetail"
                }
              }
            }
          },
          "404": {
            "description": "No todo with that id"
          }
        }
      },
      "delete": {
        "tags": [
          "todos"
        ],
        "operationId": "deleteTodo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the todo to delete",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "404": {
            "description": "No todo with that id"
          }
        }
      },
      "patch": {
        "tags": [
          "todos"
        ],
        "operationId": "updateTodo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTodoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The updated todo, or null if unknown",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "$ref": "#/components/schemas/TodoDetail"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddTodoRequest": {
        "type": "object",
        "description": "Request body for `POST /api/todos`.",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          }
        }
      },
      "Todo": {
        "type": "object",
        "description": "Wire shape of a todo. Owned by this adapter; `From` maps the core type.",
        "required": [
          "id",
          "title",
          "done"
        ],
        "properties": {
          "done": {
            "type": "boolean"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "title": {
            "type": "string"
          }
        }
      },
      "TodoDetail": {
        "type": "object",
        "description": "Wire shape of a single-todo read. (Named apart from the list DTO in\n`../route.rs` — OpenAPI schema names are global.)",
        "required": [
          "id",
          "title",
          "done"
        ],
        "properties": {
          "done": {
            "type": "boolean"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "next": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "prev": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Adjacent todo ids, present when requested with `?neighbors=true`.",
            "minimum": 0
          },
          "title": {
            "type": "string"
          }
        }
      },
      "UpdateTodoRequest": {
        "type": "object",
        "description": "Body for `PATCH /api/todos/{id}`.",
        "required": [
          "done"
        ],
        "properties": {
          "done": {
            "type": "boolean"
          }
        }
      }
    }
  }
}